---
layout: layouts/base.njk
title: Best Day Ever
description: Weekly family comics featuring Pa, Grandma Kelly, and the grandchildren.
eleventyComputed:
  olderComicImage: "{{ comics[comics.length - 2].image }}"
  olderComicUrl: "{{ comics[comics.length - 2].url }}"
---

{% set latestComic = comics | last %}
{% set olderComic = comics[comics.length - 2] %}

{% if latestComic %}
  <article class="comic-feature comic-page">
    <h2 class="comic-title">
      {{ latestComic.title }}
      <span class="comic-date">{{ latestComic.date | formatDate }}</span>
    </h2>

    <div class="comic-viewer">
      <a href="{{ latestComic.url }}">
        <img
          src="{{ latestComic.image }}"
          alt="{{ latestComic.alt }}"
          width="1536"
          height="1152"
        >
      </a>

      <div class="comic-nav-row">
        <span class="nav-disabled">← Newer Comic</span>

        {% if olderComic %}
          <a href="{{ olderComic.url }}">Older Comic →</a>
        {% else %}
          <span class="nav-disabled">Older Comic →</span>
        {% endif %}
      </div>
    </div>
  </article>
{% else %}
  <p>No comics published yet.</p>
{% endif %}

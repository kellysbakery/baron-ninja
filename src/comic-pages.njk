---
pagination:
  data: comics
  size: 1
  alias: comic
permalink: "{{ comic.url }}"
layout: layouts/base.njk
eleventyComputed:
  title: "{{ comic.title }}"
  olderComicImage: "{{ comics[pagination.pageNumber - 1].image }}"
  olderComicUrl: "{{ comics[pagination.pageNumber - 1].url }}"
---

{% set currentIndex = pagination.pageNumber %}
{% set olderComic = comics[currentIndex - 1] %}
{% set nextComic = comics[currentIndex + 1] %}

<article class="comic-feature comic-page">
  <h2 class="comic-title">
    {{ comic.title }}
    <span class="comic-date">{{ comic.date | formatDate }}</span>
  </h2>

  <div class="comic-viewer">
    <img
      src="{{ comic.image }}"
      alt="{{ comic.alt }}"
      width="1536"
      height="1152"
    >

    <div class="comic-nav-row">
      {% if nextComic %}
        <a href="{{ nextComic.url }}">← Newer Comic</a>
      {% else %}
        <span class="nav-disabled">← Newer Comic</span>
      {% endif %}

      {% if olderComic %}
        <a href="{{ olderComic.url }}">Older Comic →</a>
      {% else %}
        <span class="nav-disabled">Older Comic →</span>
      {% endif %}
    </div>
  </div>
</article>
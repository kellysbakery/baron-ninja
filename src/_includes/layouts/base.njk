<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% include "seo.njk" %}
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="theme-color" content="#f7f3ea">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="Best Day Ever">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
  <script>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(async function(OneSignal) {
      await OneSignal.init({
        appId: "28a34c31-1ec8-4fc8-9934-00a0c3060040",
      });
    });
  </script>
  <link rel="stylesheet" href="/css/site.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  {# Speed up the most likely next navigation: Older Comic #}
  {% if olderComicImage %}
    <link rel="preload" as="image" href="{{ olderComicImage }}" fetchpriority="low">
  {% endif %}

  {% if olderComicUrl %}
    <link rel="prefetch" href="{{ olderComicUrl }}">
  {% endif %}
  {% if eleventy.env.runMode == "build" %}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-BQ2FMPJ30F"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-BQ2FMPJ30F');
  </script>
  {% endif %}
</head>
<body>
  <header class="site-header">
    <div class="site-title">
      <div class="site-title-row">
        <a href="/">baron.ninja</a>
        <span>Best Day Ever Comics</span>
      </div>

      <p class="site-tagline">
        Family chaos, questionable decisions and a new comic every Sunday... maybe.
      </p>
    </div>

    <nav class="site-nav">
      <a href="/comics/">Archive</a>
      <a href="/characters/">Characters</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    © 2026 Best Day Ever Comics by Grandpa Keith & Grandma Kelly. All rights reserved.
  </footer>
  {# Hover-based prefetch (desktop only) #}
  <script src="/js/prefetch.js"></script>
</body>
</html>

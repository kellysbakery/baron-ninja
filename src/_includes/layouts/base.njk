<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% include "seo.njk" %}
  <link rel="stylesheet" href="/css/site.css">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  {# Speed up the most likely next navigation: Older Comic #}
  {% if olderComicImage %}
    <link rel="preload" as="image" href="{{ olderComicImage }}" fetchpriority="low">
  {% endif %}

  {% if olderComicUrl %}
    <link rel="prefetch" href="{{ olderComicUrl }}">
  {% endif %}

</head>
<body>
  <header class="site-header">
    <div class="site-title">
      <div class="site-title-row">
        <a href="/">baron.ninja</a>
        <span>Best Day Ever Comics</span>
      </div>

      <p class="site-tagline">
        Family chaos, questionable decisions and a new comic every Sunday... maybe.
      </p>
    </div>

    <nav class="site-nav">
      <a href="/comics/">Archive</a>
      <a href="/characters/">Characters</a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    © 2026 Best Day Ever Comics by Grandpa Keith & Grandma Kelly. All rights reserved.
  </footer>
  {# Hover-based prefetch (desktop only) #}
  <script src="/js/prefetch.js"></script>
</body>
</html>
